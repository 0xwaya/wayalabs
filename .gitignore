# ============================================================
# WayaLabs — .gitignore
# ============================================================

# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-store/

# ── Next.js build outputs ────────────────────────────────────
.next/
out/
build/
dist/

# ── Testing & coverage ───────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Environment & secrets — NEVER COMMIT ─────────────────────
.env
.env.*
!.env.example        # commit only the template, never the values
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# ── API keys, tokens, credentials ───────────────────────────
*.pem
*.key
*.crt
*.pfx
*.p12
*.p8
secrets/
credentials/
.secrets/
service-account*.json
*-credentials.json
*_rsa
*_rsa.pub
*_ecdsa
*_ecdsa.pub
*.pub

# ── Editor & OS artifacts ────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
.vscode/settings.json     # keep .vscode/extensions.json if desired
.idea/
*.swp
*.swo
*~
*.orig

# ── Debug & logs ─────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
logs/
*.log

# ── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Deployment & CI ──────────────────────────────────────────
.vercel
.netlify/
.amplify/
.serverless/
.sst/
cdk.out/

# ── Misc dev tools ───────────────────────────────────────────
.turbo/
.cache/
.parcel-cache/
storybook-static/
.chromatic/

# ── Local config overrides ───────────────────────────────────
*.local
